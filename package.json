{
  "name": "storeapp",
  "version": "1.0.1",
  "description": "Una app para gestionar inventario",
  "productName": "Store App",
  "cordovaId": "org.cordova.quasar.app",
  "capacitorId": "",
  "author": "Gonzalo Fleming <gonzafg2@gmail.com>",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "lint": "eslint --ext .js,.vue src",
    "lint:fix": "eslint --ext .js,.vue src --fix",
    "start": "node server.js",
    "heroku-postbuild": "pnpm run build",
    "deploy:preview": "pnpm run build && firebase hosting:channel:deploy preview",
    "deploy:prod": "pnpm run build && firebase deploy --only hosting"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "animate.css": "^4.1.1",
    "axios": "^1.7.7",
    "connect-history-api-fallback": "^1.6.0",
    "csv-parse": "^4.16.3",
    "express": "^4.21.1",
    "firebase": "^10.9.0",
    "quasar": "^2.16.0",
    "serve-static": "^1.16.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/eslint-parser": "^7.25.1",
    "@quasar/app-webpack": "^4.4.5",
    "ajv": "^8.18.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-vue": "^9.0.0",
    "firebase-tools": "^15.14.0",
    "vue": "^3.4.0",
    "vue-router": "^4.0.0",
    "vuex": "^4.0.0",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">= 22",
    "pnpm": ">= 10"
  },
  "browserslist": [
    "last 1 version, not dead, > 0.2%"
  ],
  "pnpm": {
    "onlyBuiltDependencies": ["core-js", "esbuild", "protobufjs", "re2"],
    "overrides": {
      "core-js": "^3.49.0"
    }
  }
}
